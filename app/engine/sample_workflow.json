{
  "nodes": [
    {
      "id": "fetch_data",
      "type": "trigger.manual",
      "data": {
        "label": "Manual Start",
        "actionKey": "database_query",
        "configurationsJson": {
          "query": "SELECT * FROM claims WHERE status = 'pending'"
        }
      }
    },
    {
      "id": "save_step",
      "type": "action",
      "data": {
        "label": "Save Locally",
        "actionKey": "save_result",
        "configurationsJson": {}
      }
    },
    {
      "id": "check_data",
      "type": "action",
      "data": {
        "label": "Validate Data",
        "actionKey": "condition_check",
        "configurationsJson": {
          "field": "saved_data",
          "op": "exists"
        }
      }
    },
    {
      "id": "on_success",
      "type": "action",
      "data": {
        "label": "Success Notification",
        "actionKey": "http_request",
        "configurationsJson": {
          "url": "https://api.internal/notify",
          "method": "POST"
        }
      }
    },
    {
      "id": "reply_success",
      "type": "end.success",
      "data": {
        "label": "Success Reply",
        "actionKey": "direct_reply",
        "configurationsJson": {
          "message": "✅ Workflow executed successfully."
        }
      }
    },
    {
      "id": "on_failure",
      "type": "end.failure",
      "data": {
        "label": "Failure Reply",
        "actionKey": "direct_reply",
        "configurationsJson": {
          "message": "❌ No data found."
        }
      }
    }
  ],
  "connections": {
    "edge-1": {
      "id": "edge-1",
      "source": "fetch_data",
      "target": "save_step"
    },
    "edge-2": {
      "id": "edge-2",
      "source": "save_step",
      "target": "check_data"
    },
    "edge-3": {
      "id": "edge-3",
      "source": "check_data",
      "target": "on_success",
      "condition": { "value": "true" }
    },
    "edge-4": {
      "id": "edge-4",
      "source": "check_data",
      "target": "on_failure",
      "condition": { "value": "false" }
    },
    "edge-5": {
      "id": "edge-5",
      "source": "on_success",
      "target": "reply_success"
    }
  }
}
